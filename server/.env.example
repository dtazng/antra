# Database
DATABASE_URL=postgres://antra:antra@db:5432/antra?sslmode=disable

# JWT — change JWT_SECRET_KEY in production (min 32 chars)
JWT_SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# Firebase Cloud Messaging (optional — set to enable push notifications)
# Value is the JSON content of your Firebase service account credentials file
FIREBASE_CREDENTIALS_JSON=

# Environment: local | staging | production
ENVIRONMENT=local

# Server
PORT=8000
